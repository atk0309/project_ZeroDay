{
  "name": "zeroday-arg",
  "version": "0.1.0",
  "private": true,
  "description": "example.com ARG hacker hunt — sequential challenges with D-Day countdown",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "tsx watch app/src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test",
    "audit": "npm audit --audit-level=high",
    "start": "tsx app/src/db/migrate.ts && tsx app/src/server.ts",
    "check-base": "node scripts/check-base.mjs",
    "pretest": "npm run check-base",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx app/src/db/migrate.ts"
  },
  "engines": {
    "node": "24.x"
  },
  "allowScripts": {
    "argon2@0.45.1": true,
    "better-sqlite3@13.0.1": true,
    "esbuild@0.28.1": true,
    "fsevents": false
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.2",
    "@fastify/view": "^12.0.0",
    "argon2": "^0.45.1",
    "better-sqlite3": "^13.0.1",
    "ejs": "^6.0.1",
    "fastify": "^5.10.0",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pngjs": "^7.0.0",
    "resend": "^6.18.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ejs": "^3.1.5",
    "@types/node": "^24.13.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pngjs": "^6.0.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
