{
  "name": "zeroday-arg",
  "version": "0.1.0",
  "private": true,
  "description": "example.com ARG hacker hunt — sequential challenges with D-Day countdown",
  "type": "module",
  "scripts": {
    "dev": "tsx watch app/src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx app/src/db/migrate.ts && tsx app/src/server.ts",
    "check-base": "node scripts/check-base.mjs",
    "pretest": "npm run check-base",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx app/src/db/migrate.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^12.0.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.11.1",
    "ejs": "^6.0.1",
    "fastify": "^5.10.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "pngjs": "^7.0.0",
    "resend": "^6.14.0",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/pngjs": "^6.0.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
