# Only used for boot-time concerns. Game-runtime values live in the admin console.
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Where the SQLite file lives.
DB_PATH=./data/zeroday.db

# Cookie signing secret. Rotate on compromise.
SESSION_SECRET=change-me-to-a-long-random-string

# Salt used to derive per-player flags. Never share or rotate mid-event.
FLAG_SECRET=change-me-to-another-long-random-string

# Public origin used to build links in emails. Single host shared across subdomains.
PUBLIC_ORIGIN=https://hack.example.com

# ── Optional: Microsoft Clarity ──────────────────────────────────────────
# Project ID for the Clarity beacon. When set, the cookie-consent banner's
# "Accept" button loads https://www.clarity.ms/tag/<id>. Leave unset to
# disable Clarity entirely — the banner still appears (it also covers the
# edge-injected Cloudflare Web Analytics disclosure), Accept just has no
# extra script to load. Toggleable without rebuild; restart the process to
# pick up a change.
# CLARITY_PROJECT_ID=your-clarity-project-id

# ── Optional: emergency admin reset ──────────────────────────────────────
# Forgot the admin password and don't have SQLite shell access? Set BOTH
# vars on the host (Railway → Variables, VPS → ops/.env) and redeploy. On
# next boot the app clears admin_password_hash so the 5-click easter egg
# at /admin/login arms again. Consume-once: the nonce is persisted in
# app_settings.admin_reset_nonce; leaving RESET_ADMIN=true across future
# redeploys does NOT keep wiping admin. To reset a second time you must
# bump RESET_ADMIN_SAFETY to a strictly higher integer AND keep RESET_ADMIN=true.
#
# SECURITY: anyone who can edit infra env vars on this host can seize the
# admin seat on next boot. Race window after reset: whoever hits
# /admin/login first sets the new password. Plan to land on the page
# yourself before redeploying, then unset both vars.
# RESET_ADMIN=true
# RESET_ADMIN_SAFETY=1

# ── Optional: mail subsystem seed ────────────────────────────────────────
# These are read once on first boot and written into app_settings (no-op if
# mail_provider is already set there). After that the admin console at
# /admin/account?section=mail is the single source of truth — env edits will
# be ignored unless you wipe the rows:
#   DELETE FROM app_settings WHERE key LIKE 'mail_%';
# Seeding never flips mail_configured=true; you still have to run the
# /admin/account/mail/test round-trip before the magic-link login is enabled.
#
# MAIL_PROVIDER is inferred when omitted: if MAIL_RESEND_API_KEY is set the
# provider defaults to "resend"; if MAIL_SMTP_HOST is set it defaults to
# "smtp". So the minimum to seed Resend on a container is one variable:
#   MAIL_RESEND_API_KEY=re_xxx_your_api_key
# MAIL_FROM defaults to recruit@example.com when not provided.

# resend (HTTP API):
# MAIL_RESEND_API_KEY=re_xxx_your_api_key
# MAIL_FROM=recruit@example.com
# MAIL_PROVIDER=resend            # optional — inferred from MAIL_RESEND_API_KEY

# smtp (nodemailer):
# MAIL_SMTP_HOST=smtp.example.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_SECURE=false
# MAIL_SMTP_USER=apikey-or-username
# MAIL_SMTP_PASS=your-smtp-password
# MAIL_FROM=recruit@example.com
# MAIL_PROVIDER=smtp              # optional — inferred from MAIL_SMTP_HOST

# ── Optional: challenge #16 (git-archaeology) secret digest override ─────
# The handler ships with a baked-in sha-256 digest of the canonical
# planted-secret line in the public seed repo. If you fork the game and
# plant your own secret (see tools/git-seed.sh), set this to the sha-256
# hex of YOUR canonical line. The env value always wins over the baked
# default, so this is the no-rebuild path for operators running custom
# seed repos. Format: 64 hex chars, no prefix.
# GIT_ARCHAEOLOGY_SECRET_DIGEST=
