# Drop-in dev env for the tester pack. Copy to .env at the repo root.
# Two secrets only — leave mail unset to use the dev_link fallback.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DB_PATH=./data/zeroday.db

# Generate fresh values for each test run if you want clean isolation.
# `openssl rand -hex 32` works on Linux/macOS.
SESSION_SECRET=tester-pack-session-secret-replace-me-with-random-32b
FLAG_SECRET=tester-pack-flag-secret-replace-me-with-random-32b

# Local hub origin. Used to build email links — irrelevant when running on dev_link.
PUBLIC_ORIGIN=http://localhost:3000

# Mail intentionally unset. With no provider, magic links and invite claim links
# surface inline as `dev_link` query strings (no real email sent).
