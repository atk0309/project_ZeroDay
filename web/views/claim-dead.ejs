<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>zeroday // dead link</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/static/recruit-flow.css">
</head>
<body class="recruit-flow">
<div class="crt-stage crt-flicker">
  <div class="screen centered">
    <div class="stack-lg" style="width: 560px; max-width: 100%;">

      <div class="row between term-xs dim">
        <span>CH://invitation</span>
        <span class="glitch">claim.example.com // transmission failed</span>
        <span>OPERATIVE</span>
      </div>

      <div class="term" style="min-height: 180px;">
        <div class="term-line"><span class="ghost">&gt;</span> <span class="warn">this link is dead.</span></div>
        <div class="term-line">&nbsp;</div>
        <div class="term-line dim">&nbsp;&nbsp;reason · <span class="warn"><%= reason %></span></div>
        <div class="term-line">&nbsp;</div>
        <div class="term-line dim">&nbsp;&nbsp;invitations are single-use, time-bound, and revocable.</div>
        <div class="term-line dim">&nbsp;&nbsp;ask the operator who sent it for a fresh token.</div>
      </div>

      <div class="row between" style="margin-top: 12px;">
        <div class="term-sm dim" style="max-width: 420px; line-height: 1.6;">
          if you got here by accident · close this tab and walk away.
        </div>
        <a href="/recruit" class="term-btn glow" style="text-decoration:none">[ open signup ]</a>
      </div>

    </div>
  </div>
</div>
</body>
</html>
